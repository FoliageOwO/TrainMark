{
  "name": "trainmark-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter trainmark-ai-web dev",
    "build:web": "pnpm --filter trainmark-ai-web build",
    "dev:infra": "docker compose -f infra/docker-compose.yml up -d",
    "stop:infra": "docker compose -f infra/docker-compose.yml down",
    "build:backend": "mvn -f backend/pom.xml package -DskipTests"
  },
  "packageManager": "pnpm@10.17.1"
}
